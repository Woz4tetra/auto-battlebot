#!/bin/bash
# Run clang-tidy on the project using the compilation database from the build directory.
# Requires: build/compile_commands.json (run cmake -B build first).

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
BUILD_DIR="$PROJECT_ROOT/build"
COMPILE_COMMANDS="$BUILD_DIR/compile_commands.json"
CLANG_TIDY_EXIT=0

CLANG_TIDY=$(which clang-tidy 2>/dev/null || echo "")
if [ -z "${CLANG_TIDY}" ]; then
    echo "Warning: clang-tidy not found. Skipping lint."
    exit 1
fi

if [ ! -f "${COMPILE_COMMANDS}" ]; then
    echo "Error: ${COMPILE_COMMANDS} not found. Run cmake -B build first." >&2
    exit 1
fi

# Source files from compile_commands.json, excluding build/ and build-test/
CPP_FILES=$(jq -r '.[].file | select(test("/build/|/build-test/") | not)' "${COMPILE_COMMANDS}" 2>/dev/null | sort -u)
if [ -z "${CPP_FILES}" ]; then
    echo "Error: No files in compile_commands.json or jq not installed." >&2
    exit 1
fi

echo "Running clang-tidy ( -p ${BUILD_DIR} )..."
set +e
echo "${CPP_FILES}" | xargs "${CLANG_TIDY}" -p "${BUILD_DIR}" 2>/dev/null
CLANG_TIDY_EXIT=$?
set -e

exit $CLANG_TIDY_EXIT
