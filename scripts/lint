#!/bin/bash
# Run clang-tidy on project source files using run-clang-tidy for parallel execution.
# Requires: build/compile_commands.json (run cmake -B build first).

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
BUILD_DIR="$PROJECT_ROOT/build"
COMPILE_COMMANDS="$BUILD_DIR/compile_commands.json"

if [ -z "$(which run-clang-tidy 2>/dev/null)" ]; then
    echo "Warning: run-clang-tidy not found. Skipping lint."
    exit 1
fi

if [ ! -f "${COMPILE_COMMANDS}" ]; then
    echo "Error: ${COMPILE_COMMANDS} not found. Run cmake -B build first." >&2
    exit 1
fi

# Only lint files under src/ — excludes build/, build-test/, and all fetched deps.
# run-clang-tidy accepts a regex as positional file arguments to filter by path.
SOURCE_FILTER="^${PROJECT_ROOT}/src/"

echo "Running clang-tidy ( -p ${BUILD_DIR} )..."
set +e
run-clang-tidy -p "${BUILD_DIR}" "$@" "${SOURCE_FILTER}"
EXIT_CODE=$?
set -e

if [ $EXIT_CODE -eq 0 ]; then
    echo "Lint passed."
else
    echo "Lint failed."
fi

exit $EXIT_CODE
